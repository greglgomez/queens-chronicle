---
import { renderRichText } from '../utils/richText';

interface Dilemma {
  id: string;
  title: string;
  prompt: string;
  resolution: {
    outcome: 'aye' | 'nay';
    narrative: string;
  };
}

interface Props {
  dilemma: Dilemma;
  threadLabel: string;
  threadHref: string | null;
}

const { dilemma, threadLabel, threadHref } = Astro.props;
const won = dilemma.resolution.outcome;
---

<article class="card dilemma-card">
  <h3>{dilemma.title}</h3>
  <p class="dilemma-card__byline">
    Plotline: {threadHref ? <a href={threadHref}>{threadLabel}</a> : threadLabel}
  </p>

  <p set:html={renderRichText(dilemma.prompt)} />

  <div class={`dilemma-card__resolution dilemma-card__resolution--${won}`}>
    <p class="dilemma-card__outcome">Resolved {won}</p>
    <p set:html={renderRichText(dilemma.resolution.narrative)} />
  </div>
</article>

<style>
  .dilemma-card__byline {
    margin: -0.5rem 0 1rem;
    font-size: 0.85rem;
    color: var(--color-ink-light);
  }

  .dilemma-card__resolution {
    border-left: 3px solid var(--color-border);
    padding: 0.25rem 0 0.25rem 1rem;
    margin-top: 1rem;
  }

  .dilemma-card__resolution > :first-child {
    margin-top: 0;
  }

  .dilemma-card__resolution > :last-child {
    margin-bottom: 0;
  }

  .dilemma-card__resolution--aye {
    border-left-color: var(--color-aye);
  }

  .dilemma-card__resolution--nay {
    border-left-color: var(--color-nay);
  }

  .dilemma-card__outcome {
    margin: 0 0 0.25rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-light);
  }

  .dilemma-card__resolution--aye .dilemma-card__outcome {
    color: var(--color-aye);
  }

  .dilemma-card__resolution--nay .dilemma-card__outcome {
    color: var(--color-nay);
  }
</style>
