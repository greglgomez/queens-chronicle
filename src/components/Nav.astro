---
const links = [
  { href: '/', label: 'The Chronicle' },
  { href: '/plot/', label: 'The Plots' },
  { href: '/players/', label: 'The Players' },
];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="nav">
  <a class="nav__brand" href={`${base}/`}>Queen's Chronicle</a>
  <ul class="nav__links">
    {links.map((link) => (
      <li><a href={`${base}${link.href}`}>{link.label}</a></li>
    ))}
  </ul>
</nav>

<style>
  .nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-parchment-dark);
  }

  .nav__brand {
    font-family: var(--font-display);
    font-size: 1.5rem;
    text-decoration: none;
    color: var(--color-ink);
  }

  .nav__links {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.25rem;
    margin: 0;
    padding: 0;
  }

  .nav__links a {
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1rem;
  }

  @media (min-width: 640px) {
    .nav {
      flex-direction: row;
      justify-content: space-between;
      padding: 1rem 2rem;
    }
  }
</style>
