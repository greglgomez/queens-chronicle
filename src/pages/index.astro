---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameNewspaperCard from '../components/GameNewspaperCard.astro';

const gameFiles = import.meta.glob('../data/games/*.json', { eager: true });
const games = Object.values(gameFiles).sort(
  (a: any, b: any) => a.gameNumber - b.gameNumber,
);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Home">
  <h1>Queen's Chronicle</h1>
  <p>
    A record of our campaign of <em>The Queen's Dilemma</em> — the dilemmas
    put before the Council, the plotlines they've unlocked, and the players
    who have shaped the realm of Ankist.
  </p>
  {games.map((game: any) => (
    <GameNewspaperCard
      gameNumber={game.gameNumber}
      summary={game.summary}
      dilemmas={game.dilemmas}
      href={`${base}/chronicle/${game.gameNumber}/`}
    />
  ))}
</BaseLayout>
