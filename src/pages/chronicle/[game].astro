---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DilemmaCard from '../../components/DilemmaCard.astro';
import plotlines from '../../data/plotlines.json';
import { resolveDilemmaThread } from '../../utils/resolveDilemmaThread';

export function getStaticPaths() {
  const gameFiles = import.meta.glob('../../data/games/*.json', { eager: true });
  return Object.values(gameFiles).map((game: any) => ({
    params: { game: String(game.gameNumber) },
    props: { game },
  }));
}

const { game } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={`Game ${game.gameNumber}`}>
  <h1>Game {game.gameNumber}</h1>
  {game.dilemmas.map((dilemma: any) => {
    const { label, href } = resolveDilemmaThread(dilemma, plotlines, base);
    return <DilemmaCard dilemma={dilemma} threadLabel={label} threadHref={href} />;
  })}
</BaseLayout>
